% ЛР2: тестовые факты и запросы для предметной области «Библиотека»

% Экземпляры понятий
instance_of(alice, AdultReader).
instance_of(bob, ChildReader).
instance_of(elena, Librarian).
instance_of(book1, Book).

% Факты о связях borrows/recommends
borrows(alice, book1).
borrows(bob, book1).
recommends(elena, book1).

